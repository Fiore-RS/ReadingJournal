NODE_ENV=development
PORT=4000

# Copy the connection string from your Neon project dashboard.
# Make sure sslmode=require is included (Neon requires SSL).
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/cozy_reading_journal?sslmode=require

# The Vite dev server origin, for CORS
CORS_ORIGIN=http://localhost:5173

# Signs and verifies login tokens. Generate a random one — never reuse this
# example value. In a terminal: openssl rand -hex 32
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=30d

# Cover images are hosted on Cloudinary (free tier) instead of local disk —
# create a free account at cloudinary.com, then copy these three from your
# dashboard (Settings -> API Keys).
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Used once by `npm run db:seed` to create the two accounts. Pick a real
# password for OWNER — this is your personal library. DEMO_* is the account
# you hand out publicly, so keep it something simple and low-stakes.
OWNER_USERNAME=your-owner-username
OWNER_PASSWORD=choose-a-real-password
OWNER_DISPLAY_NAME=Your Name

DEMO_USERNAME=demo
DEMO_PASSWORD=demo1234
DEMO_DISPLAY_NAME=Guest Reader
